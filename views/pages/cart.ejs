<%- include('../partials/head') %>
<%- include('../partials/navbar') %>

<main class="container page-space">
  <div class="page-header">
    <h2>Your Cart</h2>
    <p class="muted">Review your items before checkout.</p>
  </div>

  <% if (!items.length) { %>
    <section class="card empty-state">
      <h3>Your cart is empty</h3>
      <p>Add items from our menu to continue.</p>
      <a href="/menu" class="btn btn-primary">Go to Menu</a>
    </section>
  <% } else { %>
    <div class="cart-layout">
      <section class="card">
        <% items.forEach((item) => { %>
          <article class="cart-row">
            <div>
              <h4><%= item.name %></h4>
              <p class="muted"><%= item.category %> · R <%= Number(item.price).toFixed(2) %> each</p>
            </div>
            <form method="post" action="/cart/update" class="inline-form">
              <input type="hidden" name="itemId" value="<%= item.id %>" />
              <input type="number" name="quantity" value="<%= item.quantity %>" min="0" max="20" />
              <button type="submit" class="btn btn-outline">Update</button>
            </form>
            <form method="post" action="/cart/remove">
              <input type="hidden" name="itemId" value="<%= item.id %>" />
              <button type="submit" class="btn btn-danger">Remove</button>
            </form>
            <strong>R <%= Number(item.lineTotal).toFixed(2) %></strong>
          </article>
        <% }) %>
      </section>

      <aside class="card summary-card">
        <h3>Order Summary</h3>
        <div class="summary-row"><span>Subtotal</span><strong>R <%= Number(subtotal).toFixed(2) %></strong></div>
        <div class="summary-row"><span>Delivery</span><strong>R <%= Number(deliveryFee).toFixed(2) %></strong></div>
        <div class="summary-row total"><span>Total</span><strong>R <%= Number(total).toFixed(2) %></strong></div>
        <a href="/checkout" class="btn btn-primary btn-block">Proceed to Checkout</a>
      </aside>
    </div>
  <% } %>
</main>

<%- include('../partials/footer') %>
