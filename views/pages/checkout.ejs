<%- include('../partials/head') %>
<%- include('../partials/navbar') %>

<main class="container page-space">
  <div class="page-header">
    <h2>Checkout</h2>
    <p class="muted">Confirm your delivery details and place order.</p>
  </div>

  <% if (error) { %>
    <div class="alert error"><%= error %></div>
  <% } %>

  <div class="checkout-layout">
    <section class="card">
      <h3>Delivery Information</h3>
      <form method="post" action="/checkout/create-order" class="form-grid">
        <label>
          Address Line
          <input type="text" name="addressLine" placeholder="123 Main Street" required />
        </label>
        <label>
          City
          <input type="text" name="city" placeholder="Johannesburg" required />
        </label>
        <label>
          Notes (Optional)
          <textarea name="notes" rows="3" placeholder="Gate code, landmark, etc."></textarea>
        </label>
        <button type="submit" class="btn btn-primary">Place Order & Continue to Payment</button>
      </form>
    </section>

    <aside class="card summary-card">
      <h3>Your Items</h3>
      <% items.forEach((item) => { %>
        <div class="summary-row">
          <span><%= item.quantity %> × <%= item.name %></span>
          <strong>R <%= Number(item.lineTotal).toFixed(2) %></strong>
        </div>
      <% }) %>
      <hr />
      <div class="summary-row"><span>Subtotal</span><strong>R <%= Number(subtotal).toFixed(2) %></strong></div>
      <div class="summary-row"><span>Delivery</span><strong>R <%= Number(deliveryFee).toFixed(2) %></strong></div>
      <div class="summary-row total"><span>Total</span><strong>R <%= Number(total).toFixed(2) %></strong></div>
    </aside>
  </div>
</main>

<%- include('../partials/footer') %>
