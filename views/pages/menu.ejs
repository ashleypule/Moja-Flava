<%- include('../partials/head') %>
<%- include('../partials/navbar') %>

<main class="container page-space">
  <div class="page-header">
    <h2>Browse Menu</h2>
    <p class="muted">Pick your favorites and add them to your cart.</p>
  </div>

  <% if (success) { %>
    <div class="alert success"><%= success %></div>
  <% } %>

  <section class="menu-grid">
    <% menuItems.forEach((item) => { %>
      <article class="card menu-card">
        <div class="menu-image-wrap">
          <img
            src="/images/<%= item.image || 'logo.png' %>"
            alt="<%= item.name %>"
            class="menu-image"
            loading="lazy"
          />
        </div>
        <span class="pill"><%= item.category %></span>
        <h3><%= item.name %></h3>
        <p><%= item.description %></p>
        <div class="menu-card-bottom">
          <strong>R <%= Number(item.price).toFixed(2) %></strong>
          <form method="post" action="/cart/add" class="inline-form">
            <input type="hidden" name="itemId" value="<%= item.id %>" />
            <input type="number" name="quantity" value="1" min="1" max="10" />
            <button type="submit" class="btn btn-primary">Add</button>
          </form>
        </div>
      </article>
    <% }) %>
  </section>
</main>

<%- include('../partials/footer') %>
